#!/bin/bash
set -e

if [ "$EUID" -ne 0 ]; then
  echo "Run as root: sudo bash bd-bootstrap.sh"
  exit 1
fi

echo "=== BirdDog Bootstrap ==="

# Disable cloud-init if present (prevents hostname reset on reboot)
if [ -d /etc/cloud ]; then
  echo "Disabling cloud-init..."
  touch /etc/cloud/cloud-init.disabled
fi

read -p "Enter new hostname (e.g. bdc-01 or bdm-01): " NEW_HOSTNAME

if [[ -z "$NEW_HOSTNAME" ]]; then
  echo "Hostname cannot be empty."
  exit 1
fi

echo "=== Writing hostname deterministically ==="

# Write hostname directly
echo "$NEW_HOSTNAME" > /etc/hostname

# Update /etc/hosts safely
if grep -q "^127.0.1.1" /etc/hosts; then
  sed -i "s/^127.0.1.1.*/127.0.1.1    $NEW_HOSTNAME/" /etc/hosts
else
  echo "127.0.1.1    $NEW_HOSTNAME" >> /etc/hosts
fi

# Apply immediately
hostname "$NEW_HOSTNAME"

echo "=== Updating system ==="
apt update
apt full-upgrade -y
apt autoremove -y

echo "=== Bootstrap complete. Rebooting... ==="
reboot
