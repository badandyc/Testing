#!/bin/bash
set -e

if [ "$EUID" -ne 0 ]; then
  echo "Run as root: sudo bash bdm_mediamtx_setup"
  exit 1
fi

REAL_USER=${SUDO_USER:-$USER}
USER_HOME=$(eval echo "~$REAL_USER")
WORK_DIR="$USER_HOME/mediamtx_install"
INSTALL_DIR="/opt/mediamtx"

echo "=== Creating mediamtx user ==="
id -u mediamtx &>/dev/null || useradd -r -s /usr/sbin/nologin mediamtx

echo "=== Preparing workspace in $WORK_DIR ==="
rm -rf "$WORK_DIR"
mkdir -p "$WORK_DIR"
cd "$WORK_DIR"

echo "=== Downloading latest MediaMTX ==="
LATEST_URL=$(curl -s https://api.github.com/repos/bluenviron/mediamtx/releases/latest \
  | grep browser_download_url \
  | grep linux_arm64.tar.gz \
  | cut -d '"' -f 4)

if [ -z "$LATEST_URL" ]; then
  echo "Failed to determine latest MediaMTX release URL"
  exit 1
fi

curl -L -o mediamtx.tar.gz "$LATEST_URL"

echo "=== Extracting archive ==="
tar -xzf mediamtx.tar.gz

# Detect source location (flat or versioned directory)
if [ -f "$WORK_DIR/mediamtx" ]; then
  SRC_DIR="$WORK_DIR"
else
  SRC_DIR=$(find "$WORK_DIR" -maxdepth 1 -type d -name "mediamtx*" | head -n 1)
fi

if [ ! -f "$SRC_DIR/mediamtx" ] || [ ! -f "$SRC_DIR/mediamtx.yml" ]; then
  echo "Extraction failed — required files missing"
  exit 1
fi

echo "=== Installing to $INSTALL_DIR ==="
rm -rf "$INSTALL_DIR"
mkdir -p "$INSTALL_DIR"

mv "$SRC_DIR/mediamtx" "$INSTALL_DIR/"
mv "$SRC_DIR/mediamtx.yml" "$INSTALL_DIR/"

chown -R mediamtx:mediamtx "$INSTALL_DIR"

echo "=== Configuring MediaMTX ==="
sed -i 's/^rtspAddress:.*/rtspAddress: :8554/' "$INSTALL_DIR/mediamtx.yml" || echo "rtspAddress: :8554" >> "$INSTALL_DIR/mediamtx.yml"
sed -i 's/^api:.*/api: true/' "$INSTALL_DIR/mediamtx.yml" || echo "api: true" >> "$INSTALL_DIR/mediamtx.yml"
sed -i 's|^apiAddress:.*|apiAddress: :9997|' "$INSTALL_DIR/mediamtx.yml" || echo "apiAddress: :9997" >> "$INSTALL_DIR/mediamtx.yml"
sed -i "s|^apiAllowOrigins:.*|apiAllowOrigins: ['*']|" "$INSTALL_DIR/mediamtx.yml" || echo "apiAllowOrigins: ['*']" >> "$INSTALL_DIR/mediamtx.yml"
sed -i 's/^authMethods:.*/authMethods: []/' "$INSTALL_DIR/mediamtx.yml" || echo "authMethods: []" >> "$INSTALL_DIR/mediamtx.yml"

grep -q "^webrtc:" "$INSTALL_DIR/mediamtx.yml" || echo "webrtc: yes" >> "$INSTALL_DIR/mediamtx.yml"
grep -q "^webrtcAddress:" "$INSTALL_DIR/mediamtx.yml" || echo "webrtcAddress: :8889" >> "$INSTALL_DIR/mediamtx.yml"

echo "=== Creating systemd service ==="
cat > /etc/systemd/system/mediamtx.service <<EOF
[Unit]
Description=MediaMTX Server
After=network-online.target
Wants=network-online.target

[Service]
User=mediamtx
Group=mediamtx
ExecStart=$INSTALL_DIR/mediamtx $INSTALL_DIR/mediamtx.yml
Restart=always
RestartSec=5
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable mediamtx
systemctl restart mediamtx

echo "=== Installation complete ==="
systemctl status mediamtx --no-pager
